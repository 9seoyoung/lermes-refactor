    <!-- 등록 -->
    <insert id="insertPost" useGeneratedKeys="true" keyProperty="dto.postSn">
        INSERT INTO TB_POST (
           POST_TTL, POST_CN, POST_WRTR_SN, CO_SN, COHORT_SN,
            FORM_UUID, BBS_TYPE, BBS_SCOPE, POST_FRST_WRT_DT, POST_LAST_MDFCN_DT
        ) VALUES (
                     #{dto.postTtl}, #{dto.postCn}, #{dto.postWrtrSn},
                     #{dto.coSn}, #{dto.cohortSn}, #{uuid},
                     #{dto.bbsType},
                     #{dto.bbsScope},
                     #{dto.postFrstWrtDt}, #{dto.postLastMdfcnDt}
                 )
    </insert>

    <!-- 단건 조회 -->
    <select id="findById" resultType="com.kdt.KDT_PJT.bbs.dto.PostResponseDto">
        SELECT
            p.POST_SN,
            p.POST_TTL,
            p.POST_CN,
            p.POST_WRTR_SN,
            u.USER_NM AS postWriterName,
            p.POST_FRST_WRT_DT,
            p.POST_LAST_MDFCN_DT,
            p.DEL_YN,
            p.CO_SN,
            p.COHORT_SN,
            p.FORM_UUID,
            p.BBS_TYPE,
            p.BBS_SCOPE,
            p.VIEW_CNT
        FROM TB_POST p
                 JOIN TB_USER u ON p.POST_WRTR_SN = u.USER_SN
        WHERE p.POST_SN = #{postSn}
    </select>

    <update id="increaseViewCnt">
        UPDATE TB_POST
        SET VIEW_CNT = VIEW_CNT + 1
        WHERE POST_SN = #{postSn}
    </update>

