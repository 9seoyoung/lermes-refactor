    <!-- 수정 -->
    <update id="updatePost" parameterType="com.kdt.KDT_PJT.bbs.dto.PostRequestDto">
        UPDATE TB_POST
        SET POST_TTL = #{postTtl},
            POST_CN = #{postCn},
            BBS_SCOPE = #{bbsScope},
            BBS_TYPE = #{bbsType},
            POST_LAST_MDFCN_DT = NOW()
        WHERE POST_SN = #{postSn}
    </update>

    <!-- 삭제 (Soft Delete) -->
    <update id="softDelete" parameterType="long">
        UPDATE TB_POST
        SET DEL_YN = 1,
            POST_LAST_MDFCN_DT = NOW()
        WHERE POST_SN = #{postSn}
    </update>

