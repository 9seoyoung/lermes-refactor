    <select id="findAllResponsesBySurvey"
            resultType="com.kdt.KDT_PJT.response.dto.SrvyResponseDetailDto">
        SELECT
        R.USER_SN   AS userSn,
        U.USER_NM   AS userName,
        R.RSPNS_CN  AS response   <!-- ★ RSPSN_CN -> RSPNS_CN -->
        FROM TB_RESPONSE R
        JOIN TB_USER U ON R.USER_SN = U.USER_SN
        WHERE R.PARENT_SN = #{srvySn}
        AND R.DEL_YN = FALSE      <!-- CHAR('Y'/'N')면 AND R.DEL_YN = 'N' -->
        ORDER BY R.RSPNS_SN ASC
    </select>

