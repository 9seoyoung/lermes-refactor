    <select id="findSurveyDetailWithResponse"
            resultType="com.kdt.KDT_PJT.response.dto.SrvyResponseDetailDto">
        SELECT
        S.SRVY_SN  AS surveySn,
        S.SRVY_TTL AS title,
        R.RSPNS_CN AS response
        FROM TB_BBS_SURVEY S
        LEFT JOIN TB_RESPONSE R
        ON S.SRVY_SN = R.PARENT_SN
        AND R.USER_SN = #{userSn}
        AND R.DEL_YN  = FALSE   <!-- CHAR('Y'/'N')면 'N'으로 -->
        WHERE S.SRVY_SN = #{srvySn}
        AND S.DEL_YN  = FALSE  <!-- 여기 교체 -->
        LIMIT 1
    </select>

